{
  "name": "blog-home-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=8192 nuxt build --dotenv .env.production",
    "build:docker": "nuxt build --dotenv .env.docker.production",
    "build:test": "nuxt build --dotenv .env.test",
    "build:report": "nuxt analyze",
    "dev": "nuxt dev --port 5050 --dotenv .env.development",
    "dev:ip": "nuxt dev --port 5050 --host 0.0.0.0 --dotenv .env.development",
    "deploy": "cross-env scripts/build.sh",
    "generate": "nuxt generate --dotenv .env.production",
    "preview": "nuxt preview --dotenv .env.development",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "prettier": "prettier . --write",
    "pm2:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development"
  },
  "dependencies": {
    "@nuxt/ui": "^4.7.1",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "copy-to-clipboard": "^3.3.3",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "js-cookie": "^3.0.5",
    "md-editor-v3": "^6.5.0",
    "nuxt": "^4.4.5",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "sse.js": "^2.8.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.4.0",
    "@inspira-ui/plugins": "^0.0.1",
    "@nuxt/eslint": "^1.15.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/crypto-js": "^4.2.2",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "sitemap": "^9.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vconsole": "^3.15.1",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.vue": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{less,css}": [
      "prettier --write"
    ]
  }
}
